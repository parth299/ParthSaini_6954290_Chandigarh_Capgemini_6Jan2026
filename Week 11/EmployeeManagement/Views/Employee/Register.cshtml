@model EmployeeManagement.Models.Employee

<h2>Register Employee</h2>

<form asp-action="Register" method="post">
    <input asp-for="Name" placeholder="Name" />
    <span asp-validation-for="Name"></span><br />

    <input asp-for="Age" placeholder="Age" />
    <span asp-validation-for="Age"></span><br />

    <input asp-for="Email" placeholder="Email" />
    <span asp-validation-for="Email"></span><br />

    <input asp-for="Department" placeholder="Department" />
    <span asp-validation-for="Department"></span><br />

    <button type="submit">Register</button>
</form>

@if (TempData["Success"] != null)
{
    <p>@TempData["Success"]</p>
}