@model BookStore.Web.ViewModels.OrderListViewModel
@{
    ViewData["Title"] = "My Orders";
}

<div class="container py-4">
    <div class="row">
        <div class="col-12">
            <h1 class="mb-4">
                <i class="fas fa-receipt"></i> My Orders
            </h1>
        </div>
    </div>

    @if (Model.Orders.Any())
    {
        <div class="row">
            @foreach (var order in Model.Orders)
            {
                <div class="col-12 mb-4">
                    <div class="card order-card">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <div>
                                <h5 class="mb-0">Order #@order.OrderId</h5>
                                <small class="text-muted">Placed on @order.OrderDate.ToString("MMM dd, yyyy 'at' hh:mm tt")</small>
                            </div>
                            <div class="text-end">
                                <span class="badge fs-6 
                                    @(order.Status.ToLower() == "pending" ? "bg-warning" : 
                                      order.Status.ToLower() == "processing" ? "bg-info" : 
                                      order.Status.ToLower() == "shipped" ? "bg-primary" : 
                                      order.Status.ToLower() == "delivered" ? "bg-success" : "bg-secondary")">
                                    @order.Status
                                </span>
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-8">
                                    <h6>Items Ordered:</h6>
                                    @foreach (var item in order.OrderItems)
                                    {
                                        <div class="d-flex justify-content-between align-items-center mb-2 pb-2 border-bottom">
                                            <div class="d-flex align-items-center">
                                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                                {
                                                    <img src="@item.ImageUrl" alt="@item.Title" 
                                                         class="me-3 rounded" style="width: 50px; height: 50px; object-fit: cover;">
                                                }
                                                else
                                                {
                                                    <div class="bg-light d-flex align-items-center justify-content-center me-3 rounded" 
                                                         style="width: 50px; height: 50px;">
                                                        <i class="fas fa-book text-muted"></i>
                                                    </div>
                                                }
                                                <div>
                                                    <strong>@item.Title</strong>
                                                    <br>
                                                    <small class="text-muted">by @item.AuthorName</small>
                                                </div>
                                            </div>
                                            <div class="text-end">
                                                <div>Qty: @item.Quantity</div>
                                                <small class="text-muted">$@item.UnitPrice.ToString("F2") each</small>
                                            </div>
                                        </div>
                                    }
                                </div>
                                
                                <div class="col-md-4">
                                    <div class="order-summary bg-light p-3 rounded">
                                        <h6>Order Summary</h6>
                                        <div class="d-flex justify-content-between mb-1">
                                            <span>Items (@order.OrderItems.Sum(i => i.Quantity)):</span>
                                            <span>$@order.OrderItems.Sum(i => i.UnitPrice * i.Quantity).ToString("F2")</span>
                                        </div>
                                        <div class="d-flex justify-content-between mb-1">
                                            <span>Shipping:</span>
                                            <span class="text-success">FREE</span>
                                        </div>
                                        <hr class="my-2">
                                        <div class="d-flex justify-content-between">
                                            <strong>Total:</strong>
                                            <strong class="text-primary">$@order.TotalAmount.ToString("F2")</strong>
                                        </div>
                                        
                                        <div class="mt-3">
                                            <a href="@Url.Action("Details", "Orders", new { id = order.OrderId })" 
                                               class="btn btn-outline-primary btn-sm">
                                                <i class="fas fa-eye"></i> View Details
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-12">
                <div class="text-center py-5">
                    <i class="fas fa-receipt fa-5x text-muted mb-4"></i>
                    <h3>No orders yet</h3>
                    <p class="text-muted mb-4">You haven't placed any orders yet. Start shopping to see your order history here.</p>
                    <a href="@Url.Action("Index", "Books")" class="btn btn-primary btn-lg">
                        <i class="fas fa-shopping-bag"></i> Start Shopping
                    </a>
                </div>
            </div>
        </div>
    }
</div>

<style>
.order-card {
    transition: box-shadow 0.2s ease;
}

.order-card:hover {
    box-shadow: 0 4px 8px rgba(0,0,0,0.1) !important;
}

.order-summary {
    border: 1px solid #dee2e6;
}
</style>
