@model BookStore.Web.ViewModels.BookDetailsViewModel
@{
    ViewData["Title"] = Model.Book.Title;
}

<div class="container py-4">
    <div class="row">
        <div class="col-12 mb-3">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Home</a></li>
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Books")">Books</a></li>
                    <li class="breadcrumb-item active">@Model.Book.Title</li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="row">
        <!-- Book Image -->
        <div class="col-md-4 mb-4">
            <div class="card">
                <div class="card-body text-center">
                    @if (!string.IsNullOrEmpty(Model.Book.ImageUrl))
                    {
                        <img src="@Model.Book.ImageUrl" alt="@Model.Book.Title" 
                             class="img-fluid rounded shadow" style="max-height: 400px;">
                    }
                    else
                    {
                        <div class="bg-light d-flex align-items-center justify-content-center rounded" 
                             style="height: 400px;">
                            <i class="fas fa-book fa-5x text-muted"></i>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Book Details -->
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h2 class="mb-0">@Model.Book.Title</h2>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-sm-6">
                            <strong>Author:</strong> @Model.Book.AuthorName
                        </div>
                        <div class="col-sm-6">
                            <strong>Category:</strong> @Model.Book.CategoryName
                        </div>
                    </div>
                    
                    <div class="row mb-3">
                        <div class="col-sm-6">
                            <strong>ISBN:</strong> @Model.Book.ISBN
                        </div>
                        <div class="col-sm-6">
                            <strong>Publisher:</strong> @Model.Book.PublisherName
                        </div>
                    </div>
                    
                    <div class="row mb-3">
                        <div class="col-sm-6">
                            <strong>Published:</strong> @Model.Book.PublishedDate.ToString("MMMM yyyy")
                        </div>
                        <div class="col-sm-6">
                            <strong>Pages:</strong> @Model.Book.Pages
                        </div>
                    </div>
                    
                    <div class="row mb-4">
                        <div class="col-sm-6">
                            <strong>Price:</strong> 
                            <span class="h4 text-primary">$@Model.Book.Price.ToString("F2")</span>
                        </div>
                        <div class="col-sm-6">
                            <strong>Stock:</strong> 
                            <span class="badge @(Model.Book.Stock > 0 ? "bg-success" : "bg-danger") fs-6">
                                @(Model.Book.Stock > 0 ? $"{Model.Book.Stock} available" : "Out of stock")
                            </span>
                        </div>
                    </div>
                    
                    @if (!string.IsNullOrEmpty(Model.Book.Description))
                    {
                        <div class="mb-4">
                            <h5>Description</h5>
                            <p class="text-muted">@Model.Book.Description</p>
                        </div>
                    }
                    
                    <!-- Add to Cart Form -->
                    @if (Model.Book.Stock > 0)
                    {
                        <div class="card bg-light">
                            <div class="card-body">
                                <form method="post" asp-controller="Cart" asp-action="AddToCart" class="row g-3">
                                    <input type="hidden" name="bookId" value="@Model.Book.BookId" />
                                    
                                    <div class="col-auto">
                                        <label for="quantity" class="form-label">Quantity:</label>
                                        <select name="quantity" id="quantity" class="form-select">
                                            @for (int i = 1; i <= Math.Min(10, Model.Book.Stock); i++)
                                            {
                                                <option value="@i">@i</option>
                                            }
                                        </select>
                                    </div>
                                    
                                    <div class="col-auto d-flex align-items-end">
                                        <button type="submit" class="btn btn-success">
                                            <i class="fas fa-cart-plus"></i> Add to Cart
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning">
                            <i class="fas fa-exclamation-triangle"></i> This book is currently out of stock.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Reviews Section -->
    @if (Model.Reviews.Any())
    {
        <div class="row mt-5">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h4><i class="fas fa-star"></i> Customer Reviews (@Model.Reviews.Count)</h4>
                    </div>
                    <div class="card-body">
                        @foreach (var review in Model.Reviews)
                        {
                            <div class="review-item border-bottom pb-3 mb-3">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <div>
                                        <strong>@review.CustomerName</strong>
                                        <div class="text-warning">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                <i class="fas fa-star @(i <= review.Rating ? "text-warning" : "text-muted")"></i>
                                            }
                                        </div>
                                    </div>
                                    <small class="text-muted">@review.CreatedAt.ToString("MMM dd, yyyy")</small>
                                </div>
                                
                                @if (!string.IsNullOrEmpty(review.Comment))
                                {
                                    <p class="mb-0">@review.Comment</p>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
.review-item:last-child {
    border-bottom: none !important;
    padding-bottom: 0 !important;
    margin-bottom: 0 !important;
}
</style>
