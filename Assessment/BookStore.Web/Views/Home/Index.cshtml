@model BookStore.Web.ViewModels.HomeViewModel
@{
    ViewData["Title"] = "Home";
}

<div class="hero-section bg-primary text-white py-5">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <h1 class="display-4 fw-bold">Welcome to BookStore Pro</h1>
                <p class="lead">Discover your next favorite book from our extensive collection</p>
                <a href="@Url.Action("Index", "Books")" class="btn btn-light btn-lg">
                    <i class="fas fa-book-open"></i> Browse Books
                </a>
            </div>
            <div class="col-lg-6">
                <img src="https://via.placeholder.com/500x300/ffffff/007bff?text=BookStore+Pro" 
                     alt="BookStore Pro" class="img-fluid rounded">
            </div>
        </div>
    </div>
</div>

<section class="py-5">
    <div class="container">
        <h2 class="text-center mb-4">Featured Books</h2>
        
        @if (Model.FeaturedBooks.Any())
        {
            <div class="row">
                @foreach (var book in Model.FeaturedBooks)
                {
                    <div class="col-lg-3 col-md-4 col-sm-6 mb-4">
                        <div class="card h-100 shadow-sm">
                            <div class="card-img-container" style="height: 200px; overflow: hidden;">
                                @if (!string.IsNullOrEmpty(book.ImageUrl))
                                {
                                    <img src="@book.ImageUrl" class="card-img-top" alt="@book.Title" style="height: 100%; width: 100%; object-fit: cover;">
                                }
                                else
                                {
                                    <div class="bg-light d-flex align-items-center justify-content-center" style="height: 100%;">
                                        <i class="fas fa-book fa-3x text-muted"></i>
                                    </div>
                                }
                            </div>
                            <div class="card-body d-flex flex-column">
                                <h6 class="card-title">@book.Title</h6>
                                <p class="card-text text-muted small">by @book.AuthorName</p>
                                <p class="card-text text-muted small">@book.CategoryName</p>
                                <div class="mt-auto">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span class="h5 text-primary">$@book.Price.ToString("F2")</span>
                                        <span class="badge bg-secondary">@book.Stock in stock</span>
                                    </div>
                                    <div class="mt-2">
                                        <a href="@Url.Action("Details", "Books", new { id = book.BookId })" 
                                           class="btn btn-primary btn-sm w-100">
                                            <i class="fas fa-eye"></i> View Details
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="fas fa-book fa-4x text-muted mb-3"></i>
                <h4>No books available</h4>
                <p class="text-muted">Check back later for our latest collection.</p>
            </div>
        }
        
        <div class="text-center mt-4">
            <a href="@Url.Action("Index", "Books")" class="btn btn-outline-primary btn-lg">
                <i class="fas fa-arrow-right"></i> View All Books
            </a>
        </div>
    </div>
</section>

@if (Model.Categories.Any())
{
    <section class="bg-light py-5">
        <div class="container">
            <h2 class="text-center mb-4">Browse by Category</h2>
            <div class="row">
                @foreach (var category in Model.Categories)
                {
                    <div class="col-lg-3 col-md-4 col-sm-6 mb-3">
                        <a href="@Url.Action("Index", "Books", new { categoryId = category.CategoryId })" 
                           class="text-decoration-none">
                            <div class="card h-100 shadow-sm hover-card">
                                <div class="card-body text-center">
                                    <i class="fas fa-tags fa-2x text-primary mb-2"></i>
                                    <h6 class="card-title">@category.Name</h6>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            </div>
        </div>
    </section>
}

<style>
.hover-card:hover {
    transform: translateY(-2px);
    transition: transform 0.2s ease;
}

.hero-section {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}
</style>
