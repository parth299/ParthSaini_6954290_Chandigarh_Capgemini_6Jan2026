@model BookStore.Web.ViewModels.CartViewModel
@{
    ViewData["Title"] = "Shopping Cart";
}

<div class="container py-4">
    <div class="row">
        <div class="col-12">
            <h1 class="mb-4">
                <i class="fas fa-shopping-cart"></i> Shopping Cart
            </h1>
        </div>
    </div>

    @if (Model.Items.Any())
    {
        <div class="row">
            <!-- Cart Items -->
            <div class="col-lg-8">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">Cart Items (@Model.Items.Count)</h5>
                    </div>
                    <div class="card-body">
                        @foreach (var item in Model.Items)
                        {
                            <div class="cart-item border-bottom pb-3 mb-3">
                                <div class="row align-items-center">
                                    <div class="col-md-2">
                                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                                        {
                                            <img src="@item.ImageUrl" alt="@item.Title" 
                                                 class="img-fluid rounded" style="max-height: 80px;">
                                        }
                                        else
                                        {
                                            <div class="bg-light d-flex align-items-center justify-content-center rounded" 
                                                 style="height: 80px; width: 60px;">
                                                <i class="fas fa-book text-muted"></i>
                                            </div>
                                        }
                                    </div>
                                    
                                    <div class="col-md-4">
                                        <h6 class="mb-1">
                                            <a href="@Url.Action("Details", "Books", new { id = item.BookId })" 
                                               class="text-decoration-none">@item.Title</a>
                                        </h6>
                                        <small class="text-muted">by @item.AuthorName</small>
                                    </div>
                                    
                                    <div class="col-md-2">
                                        <span class="fw-bold">$@item.Price.ToString("F2")</span>
                                    </div>
                                    
                                    <div class="col-md-2">
                                        <form method="post" asp-action="UpdateQuantity" class="d-inline">
                                            <input type="hidden" name="bookId" value="@item.BookId" />
                                            <div class="input-group input-group-sm">
                                                <button type="submit" name="change" value="-1" 
                                                        class="btn btn-outline-secondary btn-sm">-</button>
                                                <input type="number" name="quantity" value="@item.Quantity" 
                                                       class="form-control form-control-sm text-center" 
                                                       min="1" max="@item.Stock" readonly style="max-width: 60px;">
                                                <button type="submit" name="change" value="1" 
                                                        class="btn btn-outline-secondary btn-sm">+</button>
                                            </div>
                                        </form>
                                    </div>
                                    
                                    <div class="col-md-1">
                                        <span class="fw-bold">$@(item.Price * item.Quantity).ToString("F2")</span>
                                    </div>
                                    
                                    <div class="col-md-1">
                                        <form method="post" asp-action="RemoveFromCart" class="d-inline">
                                            <input type="hidden" name="bookId" value="@item.BookId" />
                                            <button type="submit" class="btn btn-outline-danger btn-sm" 
                                                    onclick="return confirm('Remove this item from cart?')">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
                
                <div class="mt-3">
                    <a href="@Url.Action("Index", "Books")" class="btn btn-outline-primary">
                        <i class="fas fa-arrow-left"></i> Continue Shopping
                    </a>
                </div>
            </div>

            <!-- Order Summary -->
            <div class="col-lg-4">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">Order Summary</h5>
                    </div>
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-2">
                            <span>Subtotal (@Model.Items.Sum(i => i.Quantity) items):</span>
                            <span>$@Model.TotalAmount.ToString("F2")</span>
                        </div>
                        
                        <div class="d-flex justify-content-between mb-2">
                            <span>Shipping:</span>
                            <span class="text-success">FREE</span>
                        </div>
                        
                        <hr>
                        
                        <div class="d-flex justify-content-between mb-3">
                            <strong>Total:</strong>
                            <strong class="text-primary">$@Model.TotalAmount.ToString("F2")</strong>
                        </div>
                        
                        <form method="post" asp-action="Checkout">
                            <div class="d-grid">
                                <button type="submit" class="btn btn-success btn-lg">
                                    <i class="fas fa-credit-card"></i> Proceed to Checkout
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
                
                <!-- Cart Actions -->
                <div class="card mt-3">
                    <div class="card-body">
                        <h6>Need Help?</h6>
                        <ul class="list-unstyled small">
                            <li><i class="fas fa-truck text-success"></i> Free shipping on orders over $50</li>
                            <li><i class="fas fa-undo text-info"></i> 30-day return policy</li>
                            <li><i class="fas fa-shield-alt text-primary"></i> Secure checkout</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- Empty Cart -->
        <div class="row">
            <div class="col-12">
                <div class="text-center py-5">
                    <i class="fas fa-shopping-cart fa-5x text-muted mb-4"></i>
                    <h3>Your cart is empty</h3>
                    <p class="text-muted mb-4">Looks like you haven't added any books to your cart yet.</p>
                    <a href="@Url.Action("Index", "Books")" class="btn btn-primary btn-lg">
                        <i class="fas fa-book-open"></i> Start Shopping
                    </a>
                </div>
            </div>
        </div>
    }
</div>

<style>
.cart-item:last-child {
    border-bottom: none !important;
    padding-bottom: 0 !important;
    margin-bottom: 0 !important;
}
</style>
