@model BookStore.Web.ViewModels.OrderConfirmationViewModel
@{
    ViewData["Title"] = "Order Confirmed";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="text-center mb-5">
                <div class="success-icon mb-4">
                    <i class="fas fa-check-circle fa-5x text-success"></i>
                </div>
                
                <h1 class="display-4 text-success">Order Confirmed!</h1>
                <h3 class="mb-3">Thank you for your purchase</h3>
                
                <p class="text-muted mb-4">
                    Your order has been successfully placed. You will receive a confirmation email shortly.
                </p>
            </div>

            <div class="card mb-4">
                <div class="card-header bg-success text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-receipt"></i> Order #@Model.Order.OrderId
                    </h4>
                </div>
                <div class="card-body">
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <strong>Order Date:</strong><br>
                            @Model.Order.OrderDate.ToString("dddd, MMMM dd, yyyy 'at' hh:mm tt")
                        </div>
                        <div class="col-md-6">
                            <strong>Status:</strong><br>
                            <span class="badge bg-warning">Pending</span>
                        </div>
                    </div>

                    <h5 class="mb-3">Items Ordered</h5>
                    @foreach (var item in Model.Order.OrderItems)
                    {
                        <div class="d-flex align-items-center mb-3 p-3 border rounded">
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" alt="@item.Title" 
                                     class="me-3 rounded" style="width: 60px; height: 80px; object-fit: cover;">
                            }
                            else
                            {
                                <div class="bg-light d-flex align-items-center justify-content-center me-3 rounded" 
                                     style="width: 60px; height: 80px;">
                                    <i class="fas fa-book text-muted"></i>
                                </div>
                            }
                            
                            <div class="flex-grow-1">
                                <h6 class="mb-1">@item.Title</h6>
                                <p class="mb-1 text-muted small">by @item.AuthorName</p>
                                <p class="mb-0 small">Quantity: @item.Quantity | Unit Price: $@item.UnitPrice.ToString("F2")</p>
                            </div>
                            
                            <div class="text-end">
                                <strong>$@(item.UnitPrice * item.Quantity).ToString("F2")</strong>
                            </div>
                        </div>
                    }

                    <hr>

                    <div class="row">
                        <div class="col-md-6">
                            <h5>Shipping Information</h5>
                            <p class="mb-1"><strong>Address:</strong></p>
                            <p class="text-muted">@Model.Order.ShippingAddress</p>
                            
                            <p class="mb-1"><strong>Phone:</strong> @Model.Order.Phone</p>
                            <p class="mb-1"><strong>Email:</strong> @Model.Order.Email</p>
                        </div>
                        
                        <div class="col-md-6">
                            <h5>Order Summary</h5>
                            <div class="d-flex justify-content-between mb-2">
                                <span>Items (@Model.Order.OrderItems.Sum(i => i.Quantity)):</span>
                                <span>$@Model.Order.OrderItems.Sum(i => i.UnitPrice * i.Quantity).ToString("F2")</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span>Shipping:</span>
                                <span class="text-success">FREE</span>
                            </div>
                            <hr class="my-2">
                            <div class="d-flex justify-content-between">
                                <strong>Total:</strong>
                                <strong class="text-primary">$@Model.Order.TotalAmount.ToString("F2")</strong>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="text-center">
                <p class="text-muted mb-3">
                    You can track your order status in your <a href="@Url.Action("Index", "Orders")">order history</a>.
                </p>
                
                <div>
                    <a href="@Url.Action("Index", "Home")" class="btn btn-primary me-2">
                        <i class="fas fa-home"></i> Continue Shopping
                    </a>
                    <a href="@Url.Action("Index", "Orders")" class="btn btn-outline-primary">
                        <i class="fas fa-receipt"></i> View Orders
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.success-icon {
    animation: bounceIn 1s ease-out;
}

@@keyframes bounceIn {
    0% { transform: scale(0); opacity: 0; }
    50% { transform: scale(1.1); opacity: 1; }
    100% { transform: scale(1); opacity: 1; }
}
</style>
