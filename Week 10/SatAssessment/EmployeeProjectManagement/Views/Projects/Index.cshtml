 @model IEnumerable<EmployeeProjectManagement.Models.Project>

<h2>Projects</h2>

<table class="table">
<tr>
<th>Project</th>
<th>Employees</th>
</tr>

@foreach(var project in Model)
{
<tr>
<td>@project.Title</td>

<td>
@foreach(var ep in project.EmployeeProjects)
{
    @ep.Employee.Name <br/>
}
</td>

</tr>
}
</table>