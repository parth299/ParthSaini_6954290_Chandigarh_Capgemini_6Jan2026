@model BookModel

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />

<div class="container mt-5">

<h2>Edit Book</h2>

<form asp-action="EditBook" method="post">

    <input type="hidden" asp-for="BookId" />

    <div class="mb-3">
        <label class="form-label">Book Name</label>
        <input asp-for="BookName" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Author Name</label>
        <input asp-for="AuthorName" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Book Price</label>
        <input asp-for="BookPrice" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Book Category</label>
        <input asp-for="BookCategory" class="form-control" />
    </div>

    <button type="submit" class="btn btn-success">
        Update Book
    </button>

    <a asp-action="Index" class="btn btn-secondary">
        Cancel
    </a>

</form>

</div>