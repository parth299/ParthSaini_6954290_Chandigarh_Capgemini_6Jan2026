<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="utf-8" />

<meta name="viewport"
      content="width=device-width, initial-scale=1.0" />

<title>
@ViewData["Title"] - Smart Healthcare
</title>



<!-- GOOGLE FONT -->

<link rel="preconnect"
      href="https://fonts.googleapis.com" />

<link rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin />

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet" />



<!-- BOOTSTRAP -->

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />



<!-- ICONS -->

<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />



<!-- SITE CSS -->

<link rel="stylesheet"
      href="~/css/site.css"
      asp-append-version="true" />



<style>

/* GLOBAL THEME */

body {

font-family: 'Inter', sans-serif;

background:
linear-gradient(
135deg,
#eef2ff,
#f8fafc
);

color: #1f2937;

min-height: 100vh;

}



/* BACKGROUND LAYER */

.app-background {

position: fixed;

top: 0;

left: 0;

width: 100%;

height: 100%;

background:
radial-gradient(
circle at top left,
rgba(99,102,241,0.15),
transparent 60%
),
radial-gradient(
circle at bottom right,
rgba(147,51,234,0.15),
transparent 60%
);

z-index: -1;

}



/* NAVBAR */

.app-navbar {

background:
linear-gradient(
135deg,
#4f46e5,
#9333ea
);

backdrop-filter: blur(10px);

box-shadow:
0 10px 25px rgba(0,0,0,0.15);

}



.navbar-brand {

font-size: 1.25rem;

}



.brand-mark {

width: 38px;

height: 38px;

display: flex;

align-items: center;

justify-content: center;

border-radius: 10px;

background:
rgba(255,255,255,0.2);

}



.nav-link {

font-weight: 500;

opacity: 0.9;

transition: 0.25s;

}



.nav-link:hover {

opacity: 1;

transform: translateY(-1px);

}



/* BUTTONS */

.btn-light {

font-weight: 600;

border-radius: 10px;

}



.btn-outline-light {

border-radius: 10px;

}



/* MAIN CONTENT */

.main-shell {

min-height: calc(100vh - 140px);

}



/* ALERTS */

.alert {

border-radius: 12px;

font-weight: 500;

}



/* FOOTER */

.app-footer {

background:
linear-gradient(
135deg,
#4f46e5,
#9333ea
);

color: white;

padding: 20px 0;

margin-top: 40px;

font-size: 0.9rem;

box-shadow:
0 -5px 20px rgba(0,0,0,0.1);

}



/* RESPONSIVE */

@@media (max-width: 768px) {

.navbar-text {

display: none;

}

}

</style>

</head>



<body>

<div class="app-background"></div>



<!-- NAVBAR -->

<nav class="navbar navbar-expand-lg navbar-dark app-navbar">

<div class="container">

<a class="navbar-brand d-flex align-items-center gap-2 fw-bold"
   asp-controller="Home"
   asp-action="Index">

<span class="brand-mark">

<i class="fa-solid fa-hospital"></i>

</span>

<span>

Smart Healthcare

</span>

</a>



<button class="navbar-toggler"
        type="button"
        data-bs-toggle="collapse"
        data-bs-target="#navBar">

<span class="navbar-toggler-icon"></span>

</button>



<div class="collapse navbar-collapse"
     id="navBar">



<ul class="navbar-nav me-auto mb-2 mb-lg-0">

<li class="nav-item">

<a class="nav-link"
   asp-controller="Home"
   asp-action="Index">

Home

</a>

</li>



<li class="nav-item">

<a class="nav-link"
   asp-controller="Doctor"
   asp-action="Index">

Doctors

</a>

</li>



@if (Context.Session.GetString("Token") != null)
{

<li class="nav-item">

<a class="nav-link"
   asp-controller="Dashboard"
   asp-action="Index">

Dashboard

</a>

</li>



<li class="nav-item">

<a class="nav-link"
   asp-controller="Appointment"
   asp-action="Index">

Appointments

</a>

</li>



@if (Context.Session.GetString("Role") == "Doctor")
{
    <li class="nav-item">
        <a class="nav-link"
           asp-controller="Doctor"
           asp-action="Profile">
            Profile
        </a>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link"
           asp-controller="Patient"
           asp-action="Profile">
            Profile
        </a>
    </li>
}

}

</ul>



<div class="d-flex align-items-lg-center gap-2 ms-lg-auto flex-column flex-lg-row">

@if (Context.Session.GetString("Token") != null)
{

<span class="navbar-text text-white-50 small">

@Context.Session.GetString("FullName")

</span>



<a class="btn btn-outline-light btn-sm"
   asp-controller="Account"
   asp-action="Logout">

Logout

</a>

}

else
{

<a class="btn btn-outline-light btn-sm"
   asp-controller="Account"
   asp-action="Login">

Login

</a>



<a class="btn btn-light btn-sm"
   asp-controller="Account"
   asp-action="Register">

Register

</a>

}

</div>

</div>

</div>

</nav>



<!-- MAIN -->

<main class="main-shell">

<div class="container py-4 py-lg-5">

@if (TempData["Success"] != null)
{

<div class="alert alert-success shadow-sm border-0">

@TempData["Success"]

</div>

}



@if (TempData["Error"] != null)
{

<div class="alert alert-danger shadow-sm border-0">

@TempData["Error"]

</div>

}



@RenderBody()

</div>

</main>



<!-- FOOTER -->

<footer class="app-footer">

<div class="container
d-flex
flex-column
flex-md-row
align-items-md-center
justify-content-between
gap-2">

<span>

© 2026 Smart Healthcare

</span>



<span class="text-white-50">

Manage care, appointments,
and records in one place.

</span>

</div>

</footer>



<!-- SCRIPTS -->

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<script src="~/js/site.js"
        asp-append-version="true"></script>



@await RenderSectionAsync("Scripts", required: false)

</body>

</html>