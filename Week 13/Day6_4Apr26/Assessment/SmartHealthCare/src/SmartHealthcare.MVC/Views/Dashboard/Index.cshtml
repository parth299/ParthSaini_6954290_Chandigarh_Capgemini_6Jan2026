@{
    ViewData["Title"] = "Dashboard";
    var role = ViewBag.Role as string;
    var fullName = ViewBag.FullName as string;
}

<div class="dashboard-shell">

<!-- WELCOME HERO -->

<div class="welcome-card">

<h2>
Welcome,
<span>@fullName</span> 👋
</h2>

<p>
Logged in as
<span class="role-badge">
@role
</span>
</p>

</div>



@if (role == "Admin")
{

<div class="row g-4 mt-2">

<div class="col-md-3">

<div class="dash-card purple">

<i class="bi bi-people"></i>

<h6>Users</h6>

<a href="@Url.Action("Users","Admin")"
   class="dash-btn">

Manage Users

</a>

</div>

</div>



<div class="col-md-3">

<div class="dash-card blue">

<i class="bi bi-hospital"></i>

<h6>Doctors</h6>

<a href="@Url.Action("Index","Doctor")"
   class="dash-btn">

View Doctors

</a>

</div>

</div>



<div class="col-md-3">

<div class="dash-card green">

<i class="bi bi-person-check"></i>

<h6>Patients</h6>

<a href="@Url.Action("Index","Appointment")"
   class="dash-btn">

View Patients

</a>

</div>

</div>



<div class="col-md-3">

<div class="dash-card red">

<i class="bi bi-calendar-check"></i>

<h6>Appointments</h6>

<a href="@Url.Action("Index","Appointment")"
   class="dash-btn">

View All

</a>

</div>

</div>

</div>



<div class="glass-panel mt-5">

<h5>

<i class="bi bi-graph-up"></i>

Admin Reports

</h5>

<p class="text-muted">

Reports and analytics will appear here.

</p>

<a href="@Url.Action("Reports","Admin")"
   class="btn btn-dark">

View Reports

</a>

</div>

}



else if (role == "Doctor")
{

<div class="row g-4 mt-2">

<div class="col-md-4">

<div class="dash-card blue">

<i class="bi bi-calendar"></i>

<h6>Appointments</h6>

<a href="@Url.Action("Index","Appointment")"
   class="dash-btn">

View Schedule

</a>

</div>

</div>



<div class="col-md-4">

<div class="dash-card purple">

<i class="bi bi-person"></i>

<h6>Profile</h6>

<a href="@Url.Action("Profile","Patient")"
   class="dash-btn">

Edit Profile

</a>

</div>

</div>



<div class="col-md-4">

<div class="dash-card orange">

<i class="bi bi-file-medical"></i>

<h6>Prescriptions</h6>

<a href="#"
   class="dash-btn">

Manage Rx

</a>

</div>

</div>

</div>

}



else if (role == "Patient")
{

<div class="row g-4 mt-2">

<div class="col-md-4">

<div class="dash-card green">

<i class="bi bi-calendar-plus"></i>

<h6>Book Appointment</h6>

<a href="@Url.Action("Create","Appointment")"
   class="dash-btn">

Book Now

</a>

</div>

</div>



<div class="col-md-4">

<div class="dash-card blue">

<i class="bi bi-calendar-check"></i>

<h6>My Appointments</h6>

<a href="@Url.Action("Index","Appointment")"
   class="dash-btn">

View All

</a>

</div>

</div>



<div class="col-md-4">

<div class="dash-card purple">

<i class="bi bi-person"></i>

<h6>My Profile</h6>

<a href="@Url.Action("Profile", role)"
   class="dash-btn">
    Edit Profile
</a>

</div>

</div>

</div>



<div class="glass-panel mt-5">

<h5>

<i class="bi bi-stethoscope"></i>

Browse Doctors

</h5>

<p>

Find trusted healthcare professionals
from our verified network.

</p>

<a href="@Url.Action("Index","Doctor")"
   class="btn btn-primary">

Find Doctor

</a>

</div>

}

</div>



<style>

/* DASHBOARD */

.dashboard-shell {

padding: 10px;

}



/* WELCOME */

.welcome-card {

background:
linear-gradient(
135deg,
#4f46e5,
#9333ea
);

color: white;

padding: 30px;

border-radius: 16px;

margin-bottom: 25px;

box-shadow:
0 15px 40px rgba(0,0,0,0.2);

}



.welcome-card span {

font-weight: 700;

}



.role-badge {

background: rgba(255,255,255,0.2);

padding: 6px 12px;

border-radius: 8px;

margin-left: 8px;

}



/* DASH CARDS */

.dash-card {

padding: 25px;

border-radius: 16px;

color: white;

text-align: center;

transition: 0.3s;

box-shadow:
0 10px 25px rgba(0,0,0,0.1);

}



.dash-card:hover {

transform: translateY(-6px);

box-shadow:
0 15px 35px rgba(0,0,0,0.2);

}



.dash-card i {

font-size: 2.5rem;

margin-bottom: 10px;

}



/* COLORS */

.purple {

background:
linear-gradient(
135deg,
#6366f1,
#8b5cf6
);

}



.blue {

background:
linear-gradient(
135deg,
#3b82f6,
#6366f1
);

}



.green {

background:
linear-gradient(
135deg,
#10b981,
#22c55e
);

}



.red {

background:
linear-gradient(
135deg,
#ef4444,
#f97316
);

}



.orange {

background:
linear-gradient(
135deg,
#f59e0b,
#f97316
);

}



/* BUTTON */

.dash-btn {

display: inline-block;

margin-top: 12px;

padding: 8px 18px;

background: rgba(255,255,255,0.2);

color: white;

border-radius: 8px;

text-decoration: none;

transition: 0.3s;

}



.dash-btn:hover {

background: rgba(255,255,255,0.35);

}



/* PANEL */

.glass-panel {

background: white;

padding: 30px;

border-radius: 16px;

box-shadow:
0 10px 30px rgba(0,0,0,0.1);

}



/* RESPONSIVE */

@@media (max-width: 768px) {

.welcome-card {

text-align: center;

}

}

</style>