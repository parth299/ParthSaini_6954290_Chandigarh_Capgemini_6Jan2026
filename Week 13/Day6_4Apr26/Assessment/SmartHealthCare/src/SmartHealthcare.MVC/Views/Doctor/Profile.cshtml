@model SmartHealthcare.Models.DTOs.DoctorDTO

@{
    ViewData["Title"] = "Doctor Profile";
    var needsProfile = ViewBag.NeedsProfile as bool? ?? false;
}

<div class="container mt-4">
<div class="row justify-content-center">
<div class="col-md-8">

@if (needsProfile)
{
    <!-- CREATE PROFILE -->

    <div class="card border-0 shadow-lg">

        <div class="card-header bg-primary text-white p-4">
            <h3 class="mb-0">
                <i class="bi bi-person-plus"></i>
                Complete Doctor Profile
            </h3>
        </div>

        <div class="card-body p-4">

            <p class="text-muted mb-4">
                Please complete your professional profile.
            </p>

            <form asp-action="CreateProfile" method="post">

                <div asp-validation-summary="All"
                     class="alert alert-danger">
                </div>

                <!-- License Number -->

                <div class="mb-4">

                    <label class="form-label fw-bold">
                        <i class="bi bi-card-text"></i>
                        License Number *
                    </label>

                    <input name="LicenseNumber"
                           class="form-control form-control-lg"
                           required />

                </div>

                <!-- Experience -->

                <div class="mb-4">

                    <label class="form-label fw-bold">
                        <i class="bi bi-award"></i>
                        Years Of Experience *
                    </label>

                    <input name="YearsOfExperience"
                           type="number"
                           class="form-control form-control-lg"
                           required />

                </div>

                <!-- Fee -->

                <div class="mb-4">

                    <label class="form-label fw-bold">
                        <i class="bi bi-currency-rupee"></i>
                        Consultation Fee *
                    </label>

                    <input name="ConsultationFee"
                           type="number"
                           step="0.01"
                           class="form-control form-control-lg"
                           required />

                </div>

                <!-- Phone -->

                <div class="mb-4">

                    <label class="form-label fw-bold">
                        <i class="bi bi-telephone"></i>
                        Phone *
                    </label>

                    <input name="Phone"
                           type="tel"
                           class="form-control form-control-lg"
                           required />

                </div>

                <!-- Availability -->

                <div class="mb-4">

                    <label class="form-label fw-bold">
                        <i class="bi bi-check-circle"></i>
                        Availability
                    </label>

                    <select name="IsAvailable"
                            class="form-select form-select-lg">

                        <option value="true">
                            Available
                        </option>

                        <option value="false">
                            Not Available
                        </option>

                    </select>

                </div>

                <!-- BUTTONS -->

                <div class="d-grid gap-2 d-sm-flex">

                    <button type="submit"
                            class="btn btn-primary btn-lg">

                        <i class="bi bi-check-circle"></i>
                        Create Profile

                    </button>

                    <a href="@Url.Action("Index","Dashboard")"
                       class="btn btn-outline-secondary btn-lg">

                        Cancel

                    </a>

                </div>

            </form>

        </div>

    </div>
}
else
{
    <!-- DISPLAY PROFILE -->

    <div class="card border-0 shadow-lg">

        <div class="card-header bg-success text-white p-4">
            <h3 class="mb-0">
                <i class="bi bi-person-check"></i>
                Doctor Profile
            </h3>
        </div>

        <div class="card-body p-4">

            <div class="row">

                <!-- PERSONAL -->

                <div class="col-md-6">

                    <div class="profile-section">

                        <h6 class="text-muted mb-2">
                            <i class="bi bi-person"></i>
                            PERSONAL
                        </h6>

                        <hr />

                        <p>
                            <strong>Name:</strong><br />
                            <span class="ms-3">
                                @Model.FullName
                            </span>
                        </p>

                        <p>
                            <strong>Email:</strong><br />
                            <span class="ms-3">
                                @Model.Email
                            </span>
                        </p>

                        <p>
                            <strong>Phone:</strong><br />
                            <span class="ms-3">
                                @Model.Phone
                            </span>
                        </p>

                    </div>

                </div>

                <!-- PROFESSIONAL -->

                <div class="col-md-6">

                    <div class="profile-section">

                        <h6 class="text-muted mb-2">
                            <i class="bi bi-briefcase"></i>
                            PROFESSIONAL
                        </h6>

                        <hr />

                        <p>
                            <strong>License Number:</strong><br />
                            <span class="ms-3">
                                @Model.LicenseNumber
                            </span>
                        </p>

                        <p>
                            <strong>Experience:</strong><br />
                            <span class="ms-3">
                                @Model.YearsOfExperience years
                            </span>
                        </p>

                        <p>
                            <strong>Consultation Fee:</strong><br />
                            <span class="ms-3">
                                ₹@Model.ConsultationFee
                            </span>
                        </p>

                        <p>
                            <strong>Status:</strong><br />
                            <span class="ms-3">

                                @if (Model.IsAvailable)
                                {
                                    <span class="badge bg-success">
                                        Available
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">
                                        Not Available
                                    </span>
                                }

                            </span>
                        </p>

                    </div>

                </div>

            </div>

        </div>

        <div class="card-footer bg-light p-4">

            <div class="d-grid gap-2 d-sm-flex">

                <a href="@Url.Action("Index","Appointment")"
                   class="btn btn-success btn-lg">

                    View Appointments

                </a>

            </div>

        </div>

    </div>
}

</div>
</div>
</div>

<style>

.profile-section {
    background-color: #f8f9fa;
    padding: 1.5rem;
    border-radius: 0.5rem;
    border-left: 4px solid #0d6efd;
}

</style>