@model SmartHealthcare.Models.DTOs.DoctorDTO

@{
    ViewData["Title"] = "Doctor Profile";
}

<div class="doctor-profile-shell">

<!-- BACK BUTTON -->

<a href="@Url.Action("Index")"
   class="btn btn-outline-secondary mb-3">

<i class="bi bi-arrow-left"></i>

Back to Doctors

</a>



<!-- HERO HEADER -->

<div class="doctor-hero">

<div>

<h2>

<i class="bi bi-person-circle"></i>

Dr. @Model.FullName

</h2>

<p>

@string.Join(" | ",
Model.Specializations ?? new List<string>())

</p>

</div>



<span class="availability-badge
@(Model.IsAvailable ? "available" : "offline")">

@(Model.IsAvailable ? "Available" : "Unavailable")

</span>

</div>



<!-- MAIN CONTENT -->

<div class="doctor-card">

<div class="row g-4">

<!-- CONTACT -->

<div class="col-md-6">

<div class="info-box">

<h5>

<i class="bi bi-info-circle"></i>

Contact Information

</h5>



<p>

<i class="bi bi-envelope"></i>

<a href="mailto:@Model.Email">

@Model.Email

</a>

</p>



<p>

<i class="bi bi-telephone"></i>

<a href="tel:@Model.Phone">

@Model.Phone

</a>

</p>



<p>

<i class="bi bi-credit-card"></i>

<span class="license-badge">

@Model.LicenseNumber

</span>

</p>

</div>

</div>



<!-- PROFESSIONAL -->

<div class="col-md-6">

<div class="info-box">

<h5>

<i class="bi bi-briefcase"></i>

Professional Details

</h5>



<p>

<i class="bi bi-clock"></i>

<strong>

@Model.YearsOfExperience years

</strong>

experience

</p>



<p>

<i class="bi bi-cash-coin"></i>

<span class="fee-highlight">

₹ @Model.ConsultationFee

</span>

</p>



<div class="mt-2">

@foreach (var spec in
(Model.Specializations ?? new List<string>()))
{

<span class="spec-tag">

@spec

</span>

}

</div>

</div>

</div>

</div>



<hr class="my-4" />



<!-- ABOUT -->

<div class="about-box">

<h5>

<i class="bi bi-file-text"></i>

About Dr. @Model.FullName

</h5>



<p>

Dr. @Model.FullName has

@Model.YearsOfExperience years of experience in

@(Model.Specializations?.Count > 0
? string.Join(", ", Model.Specializations)
: "multiple medical fields").

The doctor is committed to providing
high-quality healthcare and ensuring
the best outcomes for patients.

</p>

</div>



<!-- FOOTER ACTION -->

<div class="doctor-footer">

@if (Model.IsAvailable)
{

<a asp-controller="Appointment"
   asp-action="Create"
   class="btn theme-btn">

<i class="bi bi-calendar-check"></i>

Book Appointment

</a>

}



<a href="@Url.Action("Index")"
   class="btn btn-outline-secondary">

Back

</a>

</div>

</div>

</div>



<style>

/* SHELL */

.doctor-profile-shell {

max-width: 900px;

margin: auto;

}



/* HERO */

.doctor-hero {

display: flex;

justify-content: space-between;

align-items: center;

background:
linear-gradient(
135deg,
#4f46e5,
#9333ea
);

color: white;

padding: 25px;

border-radius: 16px;

margin-bottom: 20px;

}



/* AVAILABILITY */

.availability-badge {

padding: 8px 14px;

border-radius: 10px;

font-weight: 600;

}



.available {

background: #dcfce7;

color: #166534;

}



.offline {

background: #fee2e2;

color: #991b1b;

}



/* CARD */

.doctor-card {

background: white;

padding: 25px;

border-radius: 16px;

box-shadow:
0 10px 25px rgba(0,0,0,0.08);

}



/* INFO */

.info-box {

background: #f8fafc;

padding: 18px;

border-radius: 12px;

box-shadow:
0 6px 15px rgba(0,0,0,0.05);

}



.info-box p {

margin-bottom: 8px;

}



/* LICENSE */

.license-badge {

background: #e5e7eb;

padding: 5px 10px;

border-radius: 6px;

}



/* FEE */

.fee-highlight {

font-size: 1.2rem;

font-weight: 700;

color: #ef4444;

}



/* TAGS */

.spec-tag {

background: #e0e7ff;

color: #3730a3;

padding: 6px 12px;

border-radius: 8px;

margin: 3px;

display: inline-block;

font-size: 0.8rem;

}



/* ABOUT */

.about-box {

background: #f8fafc;

padding: 20px;

border-radius: 12px;

}



/* FOOTER */

.doctor-footer {

display: flex;

gap: 10px;

margin-top: 20px;

}



/* BUTTON */

.theme-btn {

background:
linear-gradient(
135deg,
#4f46e5,
#9333ea
);

color: white;

border-radius: 10px;

padding: 10px 18px;

}



.theme-btn:hover {

opacity: 0.9;

}

</style>