@model SmartHealthcare.Models.DTOs.CreatePrescriptionDTO

@{
    ViewData["Title"] = "Add Prescription";
}

<div class="container mt-4">

<div class="card shadow-lg">

<div class="card-header bg-success text-white">

<h3>
<i class="bi bi-prescription"></i>
Add Prescription
</h3>

</div>

<div class="card-body">

<form asp-action="Create" method="post">

@Html.AntiForgeryToken()

<input type="hidden"
       asp-for="AppointmentId" />

<!-- Diagnosis -->

<div class="mb-3">

<label class="form-label fw-bold">
Diagnosis
</label>

<textarea asp-for="Diagnosis"
          class="form-control"
          required>
</textarea>

</div>

<!-- Notes -->

<div class="mb-3">

<label class="form-label fw-bold">
Notes
</label>

<textarea asp-for="Notes"
          class="form-control">
</textarea>

</div>

<hr />

<h5>
<i class="bi bi-capsule"></i>
Medicines
</h5>

<div id="medicineContainer">

<div class="medicine-row border p-3 mb-3">

<input name="Medicines[0].Name"
placeholder="Medicine Name"
class="form-control mb-2" />

<input name="Medicines[0].Dosage"
placeholder="Dosage"
class="form-control mb-2" />

<input name="Medicines[0].Duration"
placeholder="Duration"
class="form-control mb-2" />

<input name="Medicines[0].Instructions"
placeholder="Instructions"
class="form-control" />

</div>

</div>

<button type="button"
        class="btn btn-outline-primary"
        onclick="addMedicine()">

Add Another Medicine

</button>

<hr />

<button type="submit"
        class="btn btn-success">

Save Prescription

</button>

</form>

</div>

</div>

</div>

<script>

let index = 1;

function addMedicine()
{
    const container =
        document.getElementById("medicineContainer");

    const html =
`<div class="medicine-row border p-3 mb-3">

<input name="Medicines[${index}].Name"
placeholder="Medicine Name"
class="form-control mb-2" />

<input name="Medicines[${index}].Dosage"
placeholder="Dosage"
class="form-control mb-2" />

<input name="Medicines[${index}].Duration"
placeholder="Duration"
class="form-control mb-2" />

<input name="Medicines[${index}].Instructions"
placeholder="Instructions"
class="form-control" />

</div>`;

    container.insertAdjacentHTML(
        "beforeend",
        html
    );

    index++;
}

</script>