<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Courses</h2>
    <div>
        <a asp-action="Create" class="btn btn-success me-2">Create Course</a>
        <a asp-action="MyEnrollments" class="btn btn-primary me-2">My Enrollments</a>
        <a asp-controller="Test" asp-action="Index" class="btn btn-info">Authorization Tests</a>
    </div>
</div>

<div class="row g-4">

@foreach (var course in Model)
{
    <div class="col-md-4">

        <div class="card shadow-sm h-100">

            <div class="card-body d-flex flex-column">

                <h5 class="card-title">
                    <a asp-controller="Course"
                       asp-action="Details"
                       asp-route-id="@course.Id"
                       class="text-decoration-none">
                        @course.Title
                    </a>
                </h5>

                <p class="card-text flex-grow-1">
                    @course.Description
                </p>

                <div class="mt-auto d-flex flex-wrap gap-2">
                    <a asp-controller="Course"
                       asp-action="Details"
                       asp-route-id="@course.Id"
                       class="btn btn-primary btn-sm">
                        Details
                    </a>
                    <a asp-controller="Course"
                       asp-action="Edit"
                       asp-route-id="@course.Id"
                       class="btn btn-warning btn-sm">
                        Edit
                    </a>
                    <form asp-action="Delete" asp-route-id="@course.Id" method="post" class="d-inline">
                        <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                    </form>
                    <a asp-controller="Course"
                       asp-action="Enroll"
                       asp-route-id="@course.Id"
                       class="btn btn-primary btn-sm">
                        Enroll
                    </a>
                </div>

            </div>

        </div>

    </div>
}

</div>