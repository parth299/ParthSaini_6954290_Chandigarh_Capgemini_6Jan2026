@model IEnumerable<SmartHealthcare.Models.DTOs.AppointmentDTO>
@{
    ViewData["Title"] = "My Appointments";
    var role = ViewBag.Role as string;
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-md-6">
            <h1 class="mb-3"><i class="bi bi-calendar-check"></i> Appointments</h1>
        </div>
        <div class="col-md-6 text-end">
            @if (role == "Patient")
            {
                <a asp-action="Create" class="btn btn-success btn-lg"><i class="bi bi-plus-circle"></i> Book New Appointment</a>
            }
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="row g-4 mb-4">
            @foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 border-0 shadow-sm appointment-card">
                        <div class="card-header bg-@GetStatusColor(item.Status) text-white">
                            <div class="d-flex justify-content-between align-items-center">
                                <h6 class="mb-0"><i class="bi bi-calendar-event"></i> Appointment #@item.Id</h6>
                                <span class="badge bg-light text-dark">@item.Status</span>
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="appointment-info">
                                <p class="mb-3">
                                    <strong><i class="bi bi-person"></i> Patient:</strong><br />
                                    <span class="ms-3">@item.PatientName</span>
                                </p>
                                <p class="mb-3">
                                    <strong><i class="bi bi-hospital"></i> Doctor:</strong><br />
                                    <span class="ms-3">Dr. @item.DoctorName</span>
                                </p>
                                <p class="mb-3">
                                    <strong><i class="bi bi-clock"></i> Date & Time:</strong><br />
                                    <span class="ms-3">@item.AppointmentDate.ToString("dd-MMM-yyyy HH:mm")</span>
                                </p>
                                @if (!string.IsNullOrEmpty(item.Notes))
                                {
                                    <p class="mb-3">
                                        <strong><i class="bi bi-sticky"></i> Notes:</strong><br />
                                        <span class="ms-3 text-muted">@item.Notes</span>
                                    </p>
                                }
                            </div>
                        </div>
                        <div class="card-footer bg-light">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary w-100">
                                <i class="bi bi-info-circle"></i> View Details
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info text-center py-5" role="alert">
            <h4 class="alert-heading"><i class="bi bi-info-circle"></i> No Appointments</h4>
            <p>You haven't booked any appointments yet.</p>
            @if (role == "Patient")
            {
                <a asp-action="Create" class="btn btn-info"><i class="bi bi-plus-circle"></i> Book Your First Appointment</a>
            }
        </div>
    }
</div>

@functions {
    private string GetStatusColor(string status)
    {
        return status?.ToLower() switch
        {
            "pending" => "warning",
            "completed" => "success",
            "cancelled" => "danger",
            _ => "secondary"
        };
    }
}

<style>
    .appointment-card {
        transition: all 0.3s ease;
        border-radius: 0.5rem;
    }

    .appointment-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 16px rgba(0, 0, 0, 0.15) !important;
    }

    .appointment-info {
        background-color: #f8f9fa;
        padding: 1rem;
        border-radius: 0.25rem;
    }
</style>